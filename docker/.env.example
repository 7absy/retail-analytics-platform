# ================================================
# Azure Data Lake Storage Gen2
# ================================================
ADLS_ACCOUNT_NAME=your_storage_account_name
ADLS_ACCOUNT_KEY=your_storage_account_key

# ================================================
# Apache Airflow
# ================================================
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=generate_with_python_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"

# ================================================
# Service Ports
# ================================================
API_PORT=8000
EVENT_GENERATOR_PORT=9000

# ================================================
# Service URLs (used by Airflow DAGs)
# ================================================
API_BASE_URL=http://api-simulator:8000
EVENT_BASE_URL=http://event-generator:9000
OUTPUT_BASE=/tmp/batch

# ================================================
# Microsoft Fabric Eventstream Connection Strings
# Get these from Fabric → Eventstream → Custom endpoint
# ================================================
EVENTSTREAM_ORDERS_CONN=your_orders_eventstream_connection_string
EVENTSTREAM_CLICKSTREAM_CONN=your_clickstream_eventstream_connection_string
EVENTSTREAM_FOOTFALL_CONN=your_footfall_eventstream_connection_string